PORT=3001
NODE_ENV=development

# TxLINE — get these from the activation flow (see README)
TXLINE_BASE_URL=https://txline.txodds.com
TXLINE_JWT=your_guest_jwt_from_auth_guest_start
TXLINE_API_KEY=your_activated_api_token_from_token_activate
TXLINE_WC_COMPETITION_ID=72

# Comma-separated fixture IDs to always bootstrap on startup (for finished matches
# that have dropped off the TxLINE snapshot). Add any WC match ID here.
# Example: TXLINE_KNOWN_FIXTURE_IDS=18241006,18257739,18257865
TXLINE_KNOWN_FIXTURE_IDS=

# OpenAI — optional, AI pulse/recap will be skipped if not set
OPENAI_API_KEY=
